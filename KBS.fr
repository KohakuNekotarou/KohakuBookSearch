/*  
 * Menu definition.
 */
resource MenuDef (kSDKDefMenuResourceID)
{
	{
		// The About sub-menu item for this plug-in.
		kKBSAboutActionID,			// ActionID (kInvalidActionID for positional entries)
		kKBSAboutMenuPath,			// Menu Path.
		kSDKDefAlphabeticPosition,											// Menu Position.
		kSDKDefIsNotDynamicMenuFlag,										// kSDKDefIsNotDynamicMenuFlag or kSDKDefIsDynamicMenuFlag

		// Separator for the popup menu on the panel
		kKBSSeparator1ActionID,
		kKBSInternalPopupMenuNameKey kSDKDefDelimiterAndSeparatorPath,	// :- to mark an item as a separator.
		kKBSSeparator1MenuItemPosition,
		kSDKDefIsNotDynamicMenuFlag,

		// Search Book: run the book-wide search using the current Find/Change settings.
		kKBSSearchBookActionID,
		kKBSTargetMenuPath
		kKBSSearchBookMenuItemPosition,
		kSDKDefIsNotDynamicMenuFlag,

		// Hide Previous Chapter: toggle (check mark). Closes the previous chapter window on jump.
		kKBSHidePrevChapterActionID,
		kKBSTargetMenuPath
		kKBSHidePrevChapterMenuItemPosition,
		kSDKDefIsNotDynamicMenuFlag,

		// About this plug-in sub-menu for the popup menu on the panel
		kKBSPopupAboutThisActionID,
		kKBSTargetMenuPath
		kKBSAboutThisMenuItemPosition,
		kSDKDefIsNotDynamicMenuFlag,

	}
};

/* 
 * Action definition.
 */
resource ActionDef (kSDKDefActionResourceID)
{
	{
		kKBSActionComponentBoss, 		// ClassID of boss class that implements the ActionID.
		kKBSAboutActionID,	// ActionID.
		kKBSAboutMenuKey,	// Sub-menu string.
		kOtherActionArea,				// Area name (see ActionDefs.h).
		kNormalAction,					// Type of action (see ActionDefs.h).
		kDisableIfLowMem,				// Enabling type (see ActionDefs.h).
		kInvalidInterfaceID,			// Selection InterfaceID this action cares about or kInvalidInterfaceID.
		kSDKDefInvisibleInKBSCEditorFlag, // kSDKDefVisibleInKBSCEditorFlag or kSDKDefInvisibleInKBSCEditorFlag.

		kKBSActionComponentBoss,
		kKBSPopupAboutThisActionID,
		kSDKDefAboutThisPlugInMenuKey,	// Key to the name of this action
		kOtherActionArea,
		kNormalAction,
		kDisableIfLowMem,
		kInvalidInterfaceID,
		kSDKDefInvisibleInKBSCEditorFlag,

		kKBSActionComponentBoss,
		kKBSSearchBookActionID,
		kKBSSearchBookMenuKey,			// "Search Book"
		kOtherActionArea,
		kNormalAction,
		kDisableIfLowMem,
		kInvalidInterfaceID,
		kSDKDefInvisibleInKBSCEditorFlag,

		kKBSActionComponentBoss,
		kKBSHidePrevChapterActionID,
		kKBSHidePrevChapterMenuKey,		// "Hide Previous Chapter" (toggle, check mark)
		kOtherActionArea,
		kNormalAction,
		kCustomEnabling|kDisableIfLowMem,
		kInvalidInterfaceID,
		kSDKDefInvisibleInKBSCEditorFlag,

	}
};


