{
	kViewRsrcType,
	{
		kWildFS, k_Wild, 	kKBSResultHitNodeWidgetRsrcID + index_enUS
	}
};

/*  
 * Type definition.
 */
type KBSPanelWidget(kViewRsrcType) : PalettePanelWidget(ClassID = kKBSPanelWidgetBoss)
{
	CPanelMenuData;
};

/*
 * Result tree types (Task 2). The list on our tree boss; the row on the STOCK tree node boss
 * (nothing to replace on it yet - the row-click handler arrives in Task 3), shared by the
 * chapter and hit row resources; the hit line's colour cell on our generic-panel boss.
 */
type KBSResultListWidget(kViewRsrcType) : TreeViewWidget(ClassID = kKBSResultListWidgetBoss)
{
};

type KBSResultNodeWidget(kViewRsrcType) : PrimaryResourcePanelWidget(ClassID = kTreeNodeWidgetBoss)
{
};

type KBSColorTextWidget(kViewRsrcType) : GenericPanelWidget(ClassID = kKBSColorTextWidgetBoss)
{
};

/*  
 * PanelList definition.
 */
resource PanelList (kSDKDefPanelResourceID)
{
	{
		// 1st panel in the list
		kSDKDefPanelResourceID,		// Resource ID for this panel (use SDK default rsrc ID)
		kKBSPluginID,			// ID of plug-in that owns this panel
		kIsResizable,
		kKBSPanelWidgetActionID,	// Action ID to show/hide the panel
		"",							// panelName empty: placed via altMenu below (Plug-Ins menu, not Window) - like KESCL/KESCM.
		kKBSPanelPluginsMenuPath,	// Plug-Ins > KohakuNekotarou > KohakuBookSearch
		kKBSPanelPluginsMenuPosition,	// Alternate menu position
		0,0,						// Rsrc ID, Plugin ID for a PNG icon resource to use for this palette
		c_Panel
	}
};

/* 
 * PanelView definition.
 * Note: it is not necessary to use EVE for panels.
 * The view is not currently localised: therefore, it can reside here.
 * However, if you wish to localise it, it is recommended to locate it in one of
 * the localised framework resource files (i.e. KBS_enUS.fr etc.).
 */
resource KBSPanelWidget(kSDKDefPanelResourceID + index_enUS)
{
	__FILE__, __LINE__,					// Localization macro
	kKBSPanelWidgetID,					// WidgetID
	kPMRsrcID_None,						// RsrcID
	kBindNone,							// Binding (0=none)
	Frame(0, 0, 300, 360),				// Default size (207x32 -> 300x360 with the result tree,
										// Task 2). Resizable (kIsResizable in PanelList).
	kTrue, kTrue,						// Visible, Enabled
	kTrue,								// Erase background (kFalse -> kTrue with the tree)
	kInterfacePaletteFill,				// Erase to color
	kFalse,								// Draw dropshadow
	kKBSPanelTitleKey,					// Panel name
	{
		// Status read-out at the top: the search summary (total hits / chapters). Bound to the
		// top edge so it stays put as the panel resizes.
		StaticTextWidget
		(
			kKBSStaticTextWidgetID,			 // WidgetId
			kSysStaticTextPMRsrcId,			 // RsrcId
			kBindLeft | kBindRight | kBindTop, // Frame binding
			Frame(5, 6, 295, 23),			 // Frame: left, top, right, bottom.
			kTrue, kTrue,					 // Visible, Enabled
			kAlignLeft, kEllipsizeEnd, kTrue // Alignment, ellipsize style, convert ampersands
			kKBSStaticTextKey,				// Initial text.
			0								// No associated widget
		),

		// Result tree: chapter -> hit rows, filling the rest of the panel and bound to all four
		// edges so it grows with the window. Root hidden, single selection, vertical scroll bar
		// only; scroll increments = one 19px row.
		KBSResultListWidget
		(
			kKBSResultListWidgetID, kPMRsrcID_None,	// WidgetId, RsrcId
			kBindAll,						// Frame binding: grow with the panel
			Frame(4, 26, 296, 356),			// Frame (below the status line to the panel's edges)
			kTrue, kTrue,					// Visible, Enabled
			kTrue,							// EraseBeforeDraw
			kInterfacePaletteFill,			// InterfaceColor
			"",								// Panel name
			kHideRootNode,					// Options: the root is not a row
			kFalse,							// Use H scroll bar
			kTrue,							// Use V scroll bar
			19,								// fVScrollButtonIncrement (one row)
			19,								// fVThumbScrollIncrement
			19,								// fHScrollButtonIncrement (unused, no H bar)
			19,								// fHThumbScrollIncrement
			1,								// Items selectable: 1 = single selection
			kFalse,							// Allow children from multiple parents to be selected
			kFalse,							// Allow discontiguous selection
			{
			},
		),
	}

	kKBSInternalPopupMenuNameKey		// Popup menu name (internal)
};

/*
 * One CHAPTER row of the result tree, created at runtime by KBSResultListWidgetMgr for chapter
 * nodes: a stock expander arrow (hidden by the widget manager on a childless chapter - never in
 * practice) and the chapter's "<name>  (N)" label after the expander's zone. The widget manager
 * owns the runtime layout; these frames are only the default state.
 */
resource KBSResultNodeWidget(kKBSResultChapterNodeWidgetRsrcID + index_enUS)
{
	__FILE__, __LINE__,
	kKBSResultChapterNodeWidgetID, kPMRsrcID_None,	// WidgetId, RsrcId
	kBindLeft | kBindRight,				// Frame binding: follow the list's width
	Frame(0, 0, 296, 19),				// Frame (left, top, right, bottom)
	kTrue, kTrue,						// Visible, Enabled
	"",									// Panel name
	{
		// The expand / collapse arrow (stock part; the tree framework owns its clicks and its
		// collapsed / expanded state icon). Field-for-field the paneltreeview sample's.
		TreeExpanderWidget
		(
			kTreeNodeExpanderWidgetID,		// WidgetId
			kTreeBranchCollapsedRsrcID,		// RsrcId for collapsed node icon
			kApplicationRsrcPluginID,		// RsrcPlugin for collapsed node icon
			kBindNone,						// Frame binding
			Frame(2, 1, 18, 17),			// Frame (inside the 19px row)
			kTrue, kTrue,					// Visible, Enabled
			kTreeBranchExpandedRsrcID, 		// RsrcId for expanded node icon
			kApplicationRsrcPluginID,		// RsrcPlugin for expanded node icon
			kTrue,							// Cmd-Click expands/collapses children
			kFalse,							// Scroll to show children when expanded
			kIconNoCentering,
			kIconRaisedLook,				// Icon look
			kFalse							// Draws a well
		),

		InfoStaticTextWidget
		(
			kKBSResultChapterLabelWidgetID,	// WidgetId
			kPMRsrcID_None,					// RsrcId
			kBindLeft | kBindRight,			// Frame binding: take the rest of the row
			Frame(18, 1, 292, 17),			// Frame
			kTrue, kTrue,					// Visible, Enabled
			kAlignLeft,						// Alignment
			kEllipsizeEnd, kTrue,			// Ellipsize style, Convert ampersands
			"",								// Text Control Data
			0,								// WidgetId for associated control for shortcut focus
			kPaletteWindowSystemScriptFontId, kPaletteWindowSystemScriptFontId,
		),
	}
};

/*
 * One HIT row of the result tree: the match's line in the custom multi-colour text cell
 * (KBSColorTextView highlights the matched part). No expander (a leaf); the widget manager
 * indents the cell one expander zone deeper than the chapter row's text at apply time, so this
 * frame is only the default state.
 */
resource KBSResultNodeWidget(kKBSResultHitNodeWidgetRsrcID + index_enUS)
{
	__FILE__, __LINE__,
	kKBSResultHitNodeWidgetID, kPMRsrcID_None,	// WidgetId, RsrcId
	kBindLeft | kBindRight,				// Frame binding: follow the list's width
	Frame(0, 0, 296, 19),				// Frame (left, top, right, bottom)
	kTrue, kTrue,						// Visible, Enabled
	"",									// Panel name
	{
		KBSColorTextWidget
		(
			kKBSResultTextWidgetID, kPMRsrcID_None,	// WidgetId, RsrcId
			kBindLeft | kBindRight,			// Frame binding: take the rest of the row
			Frame(34, 1, 292, 17),			// Frame (indented; the widget manager re-places it)
			kTrue, kTrue,					// Visible, Enabled
			"",								// Panel name
			{
			}
		),
	}
};

