/*
 * LocaleIndex wrappers for the result tree's row resources (Task 2). KBSResultListWidgetMgr
 * creates these at runtime via RsrcSpec(..., kViewRsrcType, <base RsrcID>); these map that base
 * ID to the +index_enUS body. The rows carry no localized strings (text is stamped at runtime),
 * so one wild locale suffices.
 */
resource LocaleIndex (kKBSResultChapterNodeWidgetRsrcID)
{
	kViewRsrcType,
	{
		kWildFS, k_Wild, 	kKBSResultChapterNodeWidgetRsrcID + index_enUS
	}
};

