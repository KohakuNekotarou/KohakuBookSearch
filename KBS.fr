};

/*  
 * The ExtraPluginInfo resource adds extra information to the Missing Plug-in dialog
 * that is popped when a document containing this plug-in's data is opened when
 * this plug-in is not present. These strings are not translatable strings
 * since they must be available when the plug-in isn't around. They get stored
 * in any document that this plug-in contributes data to.
 */
resource ExtraPluginInfo(1)
{
	kKBSCompanyValue,			// Company name
	kKBSMissingPluginURLValue,	// URL 
	kKBSMissingPluginAlertValue,	// Missing plug-in alert text
};

/* 
 * Boss class definitions.
 */
resource ClassDescriptionTable(kSDKDefClassDescriptionTableResourceID)
{{{

	/*
	 * This boss class supports two interfaces:
	 * IActionComponent and IPMPersist.
     *
	 * 
	 * @ingroup kohakubooksearch
	 */
	Class
	{
		kKBSActionComponentBoss,
		kInvalidClass,
		{
			// Handle the actions from the menu.
			IID_IACTIONCOMPONENT, kKBSActionComponentImpl,
			// Persist the state of the menu across application instantiation. Implementation provided by the API.
			IID_IPMPERSIST, kPMPersistImpl
		}
	},

    /*
	 * This boss class inherits from an API panel boss class, and
	 * adds an interface to control a pop-up menu on the panel.
	 * The implementation for this interface is provided by the API.
     *
	 * 
	 * @ingroup kohakubooksearch
	 */
	Class
	{
		kKBSPanelWidgetBoss,
		kPalettePanelWidgetBoss,
		{
			/*
			 * The plug-in's implementation of ITextControlData with an exotic IID of IID_IPANELMENUDATA.
			 * Implementation provided by the API.
			 */
			IID_IPANELMENUDATA, kCPanelMenuDataImpl,
		}
	},

	/*
	 * Result tree list (Task 2): the tree-view widget carrying our hierarchy adapter and row
	 * widget manager. The framework provides the tree controller and default event handling
	 * (selection, expand/collapse); the row-click jump handler arrives in Task 3.
	 */
	Class
	{
		kKBSResultListWidgetBoss,
		kTreeViewWidgetBoss,
		{
			IID_ITREEVIEWHIERARCHYADAPTER, kKBSResultListAdapterImpl,
			IID_ITREEVIEWWIDGETMGR, kKBSResultListWidgetMgrImpl,
		}
	},

	/*
	 * The hit line's multi-colour text cell (Task 2): a generic panel widget whose IControlView
	 * is our self-drawing view (KBSColorTextView), plus the per-row draw data it paints.
	 */
	Class
	{
		kKBSColorTextWidgetBoss,
		kGenericPanelWidgetBoss,
		{
			IID_ICONTROLVIEW, kKBSColorTextViewImpl,
			IID_IKBSROWDATA, kKBSRowDataImpl,
		}
	},

}}};

