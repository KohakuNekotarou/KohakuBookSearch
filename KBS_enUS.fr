#ifdef __ODFRC__

// English string table is defined here

resource StringTable (kSDKDefStringsResourceID + index_enUS)
{
        k_enUS,									// Locale Id
        kEuropeanWinToMacEncodingConverter,		// Character encoding converter (irp) I made this WinToMac as we have a bias to generate on Win...
        {
        	 // ----- Menu strings
                kKBSCompanyKey,					"Kohaku Plug-Ins",	// menu-group display name (KESCM-style; distinct from kKBSCompanyValue)
                kKBSAboutMenuKey,					kKBSPluginName "...",
                kKBSPluginsMenuKey,				kKBSPluginName,
	
                kSDKDefAboutThisPlugInMenuKey,			kSDKDefAboutThisPlugInMenuValue_enUS,

                // ----- Command strings
                kKBSSearchBookMenuKey,			"Search Book",
                kKBSHidePrevChapterMenuKey,		"Hide Previous Chapter",

                // ----- Window strings

                // ----- Panel/dialog strings
                kKBSPanelTitleKey,				kKBSPluginName,
                kKBSStaticTextKey,				kKBSPluginName,


		// ----- Misc strings
                kKBSAboutBoxStringKey,			kKBSPluginName ", version " kKBSVersion " by " kKBSAuthor "\n\n" kSDKDefCopyrightStandardValue "\n\n" kSDKDefPartnersStandardValue_enUS,

		
        }

};

#endif // __ODFRC__
